# Copy to server/.env and fill in values.

# ── Database ──────────────────────────────────────────────────────────────────
# @db:5432 = Docker service name. Change to @localhost:5432 for local cargo run.
DATABASE_URL=postgres://USER:PASSWORD@db:5432/taxchain

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=                          # 64-char hex — generate with: openssl rand -hex 32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Wallet encryption ─────────────────────────────────────────────────────────
WALLET_ENCRYPTION_KEY=               # 64-char hex — generate with: openssl rand -hex 32

# ── Blockchain (Sepolia) ──────────────────────────────────────────────────────
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY_HERE
INVOICE_REGISTRY_ADDRESS=0x5689C9BF6A5d5d4B64628816b0d58d16BC9AF8B4

# ── Server ────────────────────────────────────────────────────────────────────
RUST_LOG=debug
PORT=8080

# ── Deployment ────────────────────────────────────────────────────────────────
# Private key of the deployer wallet (hex, no 0x prefix).
# Fund it with Sepolia ETH from https://sepoliafaucet.com before deploying.
DEPLOYER_PRIVATE_KEY=

# Sepolia RPC — get a free key from https://alchemy.com or https://infura.io
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY_HERE

# Etherscan API key — for verifying the contract source on Sepolia Etherscan
# https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# ── Deployed contract (Sepolia) ───────────────────────────────────────────────
# Verified at: https://sepolia.etherscan.io/address/0x5689c9bf6a5d5d4b64628816b0d58d16bc9af8b4
INVOICE_REGISTRY_ADDRESS=0x5689C9BF6A5d5d4B64628816b0d58d16BC9AF8B4
